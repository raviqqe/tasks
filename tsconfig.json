{
  "extends": "@raviqqe/react-tsconfig",
  "compilerOptions": {
    "noUncheckedSideEffectImports": false,
    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "goToDefinition": true,
          "noUncheckedIndexedAccess": true
        }
      }
    ]
  }
}
